    <title>Sektörel Blog | Rulman Satış</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@800&family=Poppins:wght@300;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../style.css">
    <style>
        .blog-hero { padding: 150px 5% 50px; text-align: center; background: #fcfcfc; }
        .blog-container { max-width: 1200px; margin: 0 auto; padding: 40px 5% 100px; display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 30px; }
        
        /* Haber Kartı Modülü */
        .post-card {
            background: #fff; border-radius: 15px; overflow: hidden; border: 1px solid #eee;
            text-decoration: none; color: inherit; display: flex; flex-direction: column; transition: 0.3s;
        }
        .post-card:hover { transform: translateY(-10px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); border-color: var(--neon); }
        .post-thumb { width: 100%; height: 220px; object-fit: cover; }
        .post-content { padding: 25px; flex-grow: 1; }
        .post-date { color: var(--blue); font-size: 0.8rem; font-weight: 700; margin-bottom: 10px; display: block; }
        .post-content h2 { font-family: 'Montserrat'; font-size: 1.3rem; margin: 0 0 12px 0; line-height: 1.4; }
        .post-content p { font-size: 0.9rem; color: #666; margin-bottom: 20px; }
        .read-btn { color: var(--dark); font-weight: 600; font-size: 0.85rem; text-transform: uppercase; border-bottom: 2px solid var(--neon); }
    </style>
</head>

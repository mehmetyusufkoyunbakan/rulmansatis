<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog | Rulman Satış - Teknik Makaleler</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@800&family=Poppins:wght@300;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../style.css">
    <style>
        .blog-header { padding: 140px 5% 60px; text-align: center; background: var(--light); }
        .blog-header h1 { font-family: 'Montserrat'; font-size: 2.5rem; color: var(--blue); margin-bottom: 10px; }
        
        .blog-wrapper { max-width: 1200px; margin: 0 auto; padding: 40px 5% 100px; }
        
        /* Kemik Grid Yapısı */
        .blog-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); 
            gap: 40px; 
        }

        /* Haber Kartı Modülü */
        .post-card {
            background: #fff;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            border: 1px solid #eee;
            transition: all 0.3s ease;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
        }

        .post-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            border-color: var(--neon);
        }

        .post-thumb { width: 100%; height: 230px; object-fit: cover; }
        
        .post-info { padding: 25px; flex-grow: 1; display: flex; flex-direction: column; }
        .post-date { font-size: 0.8rem; font-weight: 700; color: var(--blue); margin-bottom: 12px; display: block; }
        .post-info h2 { font-family: 'Montserrat'; font-size: 1.35rem; margin: 0 0 15px 0; line-height: 1.3; color: var(--dark); }
        .post-info p { font-size: 0.95rem; color: #64748b; margin-bottom: 20px; line-height: 1.6; }
        
        .post-link { 
            margin-top: auto; 
            font-weight: 600; 
            font-size: 0.9rem; 
            color: var(--dark); 
            display: flex; 
            align-items: center; 
            gap: 8px; 
        }
        .post-link::after { content: '→'; transition: 0.2s; color: var(--neon); font-size: 1.2rem; }
        .post-card:hover .post-link::after { transform: translateX(5px); }

        @media (max-width: 480px) { .blog-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

    <header>
        <div class="nav-container">
